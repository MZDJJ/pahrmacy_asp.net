@model pahrmacy.Models.useraccounts

@{
    ViewData["Title"] = "Login";
}
@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Login Page</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background-image: url('/images/pharmacy.jpg');
            background-size: cover;
        }

        .login-form {
            background-color: alpha;
            padding: 40px;
            border-radius: 20px;
            margin-top: 100px;
            box-shadow: 0 0 20px rgba(0,0,0,0.3);
        }
    </style>
</head>
<body >
 <div class="container d-flex justify-content-center">
    <form asp-action="Login" class="login-form col-md-4"  id="LoginForm">
      <h2 class="text-center ">Login</h2>
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="na" id = "username" maxlength="12" required class="form-control">
      </div>
      <div  class="form-group">
        <label>Password</label>
        <input type="password" name="pa" required class="form-control" placeholder="Enter your password">
      </div>
      <div class="form-check">
       <input type="checkbox" name="auto" value="auto-login" />
       <label for=" auto-login">Remember me </label>
      </div>
      <button class="btn btn-success btn-block" type="submit">Login</button>
      <p class="mt-2 text-center"><a asp-action="Registration" >Don't have an account?</a></p>
      <p style="color:red ; font-size 2.2rem; ">@ViewData["Message"]</p>
    </form>
  </div
   
</body>
</html>