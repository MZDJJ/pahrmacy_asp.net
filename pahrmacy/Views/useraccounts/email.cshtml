
@{
    ViewData["Title"] = "email";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    <style >
    body {
        background-color: #f4f8f6;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    h1 {
        text-align: center;
        color: #2e7d32;
        margin-bottom: 25px;
    }

    form {
        max-width: 420px;
        margin: 40px auto;
        background: #ffffff;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.08);
    }

    .form-group label {
        font-weight: 600;
        color: #2e7d32;
        margin-bottom: 6px;
        display: block;
    }

    .form-control,
    textarea {
        border-radius: 8px;
        border: 1px solid #cfd8dc;
        padding: 10px;
    }

    textarea {
        width: 100%;
        resize: none;
    }

    .btn {
        background-color: #2e7d32;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        width: 100%;
        margin-top: 15px;
        font-weight: 600;
    }

        .btn:hover {
            background-color: #256628;
        }

    p {
        text-align: center;
        margin-top: 15px;
        color: #2e7d32;
        font-weight: 500;
    }
</style>

</style>

<h1>email</h1>



<body>


    <form asp-action="email">
        <div class="form-group">
            <label class="control-label"> address</label>
            <input name="address" class="form-control" /> <br />
        </div>
        <div class="form-group">
            <label for="subject" class="control-label"> Subject</label>
            <input name="subject" class="form-control" /> <br />
        </div>
        <div class="form-group">
            <label for="body" class="control-label"> Body</label>
            <textarea name="body" rows="4" cols="50"> </textarea>


        </div>
        <input type="submit" value="Send" class="btn btn-default" />
        <p> @ViewData["message"]</p>
    </form>



</body> 