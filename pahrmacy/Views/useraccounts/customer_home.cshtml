@model IEnumerable<pahrmacy.Models.items>

@{
    
    Layout = "~/Views/Shared/_Layout1.cshtml";
}






<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Items</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap (اختياري) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* General */
        body {
            background-color: #f4f8f6;
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
        }

        /* Page title */
        h4 {
            color: #2e7d32; /* أخضر طبي */
            font-weight: 700;
            font-size: 26px;
            text-align: center;
            margin: 30px 0;
            padding: 10px 20px;
            border-left: 6px solid #66bb6a;
            border-right: 6px solid #66bb6a;
            display: inline-block;
            background-color: #e8f5e9;
            border-radius: 8px;
        }

        /* Card */
        .card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
            margin-bottom: 25px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            background-color: #ffffff;
        }

            /* Hover effect */
            .card:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
            }

        /* Card header */
        .card-header {
            background-color: #e8f5e9;
            color: #2e7d32;
            font-weight: 600;
            text-align: center;
            border-bottom: none;
            border-radius: 14px 14px 0 0;
        }

        /* Card body */
        .card-body {
            text-align: center;
            padding: 20px;
        }

            .card-body img {
                max-width: 100%;
                object-fit: contain;
                border-radius: 8px;
            }

        /* Card footer */
        .card-footer {
            background-color: #ffffff;
            border-top: none;
            text-align: center;
            padding-bottom: 18px;
        }

            /* Details link */
            .card-footer a {
                display: inline-block;
                background-color: #2e7d32;
                color: #ffffff;
                padding: 6px 16px;
                border-radius: 20px;
                text-decoration: none;
                font-size: 14px;
                transition: background-color 0.2s ease;
            }

                .card-footer a:hover {
                    background-color: #1b5e20;
                    color: #ffffff;
                }

        /* Responsive spacing */
        @@media (max-width: 768px) {
            .col-md-3

        {
            margin-bottom: 20px;
        }

        }
    </style>
</head>
<body>

    <h4>Welcome to our Website <p style="font:bold;color:red"> @ViewData["name"]</p>  </h4>
            <hr></hr>

    <h4>This is our Discounts products</h4>

    <div class="container-fluid">
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-header">
                            @item.name
                        </div>
                        <div class="card-body">
                            <img src="~/images/@item.imgfile" height="150" />
                        </div>
                        <div class="card-footer">
                            <a asp-controller="items"
                               asp-action="Details1"
                               asp-route-id="@item.Id">Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

</body>
</html>
