@{ Layout = null; }
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    body {
        background: #f4f8f6;
        font-family: Segoe UI,Tahoma,Arial
    }
</style>

<style>

    /* Page title */
    h1 {
        text-align: center;
        color: #2e7d32;
        margin-bottom: 30px;
        font-weight: 600;
    }

    /* Form box */
    .col-md-4 {
        background: #ffffff;
        padding: 25px;
        border-radius: 14px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);

    }

    /* Inputs & selects */
    .form-control {
        border-radius: 8px;
        border: 1px solid #cfd8dc;
        padding: 10px;
        margin-top: 5px;
    }

        .form-control:focus {
            border-color: #4caf50;
            box-shadow: 0 0 0 2px rgba(76,175,80,.2);
        }

    /* Labels text spacing */
    .form-group {
        margin-bottom: 15px;
        color: #2e7d32;
        font-weight: 500;
    }

    /* Radio & checkbox */
    .checkbox label {
        color: #555;
        font-weight: normal;
    }

    
    .btn-primary {
        width: 100%;
        border-radius: 8px;
        background: #4caf50;
        border: none;
        font-weight: 600;
    }

        .btn-primary:hover {
            background: #43a047;
        }

   
    h2 {
        text-align: center;
        color: #2e7d32;
        margin-top: 20px;
    }

    .row {
        justify-content: center;
    }

    .col-md-4 {
        margin: 0 auto;
    }


</style>


<h1>registration</h1>
<div class="row">
    <div class="col-md-4">
        <form asp-action="registration" onsubmit="return validateForm()">
            <div class="form-group">name<input name="name" class="form-control" /></div>
            <div class="form-group">Password<input name="pass" type="password" id="pass" class="form-control" required></div>
            <div class="form-group">Confirm Password<input type="password" id="confpass" class="form-control" required></div>
            <div class="form-group"> Email<input name="email" type="email" class="form-control" /></div>
            Job:<select class="form-control" name="job">
                <option value="HighSchool">teacher</option>
                <option value="University">doctor</option>
                <option value="University">engineer</option>
                <option value="University">HR</option>
            </select>
            <div class="form-group">
                <div class="checkbox"><label> <input type="radio" name="gender" value="male" /> Male</label></div>
                <div class="checkbox"><label> <input type="radio" name="gender" value="female" />Female</label></div>
            </div>
            <div class="form-group"><div class="checkbox"><label><input type="checkbox" name="married" /> married </label></div></div>
            <div class="form-group"> location <textarea name="location" class="form-control" rows="4"></textarea> </div>
            <div class="form-group"><input type="submit" value="Register" class="btn btn-primary" /> </div>
        </form>
    </div>
</div>
<h2>@ViewData["Message"]</h2>
<script>
    function validateForm() {
        var password = document.getElementById("pass").value;
        var confirm_password = document.getElementById("confpass").value;
        if (password != confirm_password) {
            alert("Passwords do not match!");
            return false;
        }
        return true;
    }
</script>

