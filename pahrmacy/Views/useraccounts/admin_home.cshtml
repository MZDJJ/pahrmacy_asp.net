
@{
    ViewData["Title"] = "admin_home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin.css" />
    <style>

        /* Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
        }

        /* Center container */
        .admin-container {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        /* Card */
        .admin-card {
            background: white;
            padding: 50px 80px;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            animation: fadeIn 1s ease-in-out;
        }

            .admin-card h1 {
                font-size: 2.2rem;
                color: #555;
                margin-bottom: 10px;
            }

            .admin-card h2 {
                font-size: 2.8rem;
                color: #1e3c72;
                font-weight: bold;
            }

        /* Animation */
        @@keyframes fadeIn {
            from{

        
            opacity: 0;
            transform: translateY(20px);
            }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>

</head>
<body>

    <div class="admin-container">
        <div class="admin-card">
            <h1>Welcome</h1>
            <h2>@ViewData["name"]</h2>
        </div>
    </div>

</body>
</html>



